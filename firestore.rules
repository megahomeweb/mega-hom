rules_version = '2';

// megahome.uz Firestore security rules — the real RBAC boundary.
//
// Ranks mirror lib/roles.ts EXACTLY:
//   owner 4 · admin 3 · manager 2 · staff 1 · user 0 (storefront only)
// Role is read from the caller's UID-KEYED user doc (user/<uid>); a disabled
// account drops to rank -1. Capability by rank:
//   read products/categories: public        write: manager+ (2)
//   orders: read/update(status) staff+ (1)  create: anyone  delete: admin+ (3)
//   customers (CRM/PII): manager+ (2)
//   user docs: read own or admin+; manage others admin+ (never self, never a
//   rank >= your own) so there's no privilege escalation or self-lockout.

service cloud.firestore {
  match /databases/{database}/documents {

    function profile() {
      return get(/databases/$(database)/documents/user/$(request.auth.uid)).data;
    }
    function hasProfile() {
      return request.auth != null && exists(/databases/$(database)/documents/user/$(request.auth.uid));
    }
    function roleRank(role) {
      return role == 'owner' ? 4
           : role == 'admin' ? 3
           : role == 'manager' ? 2
           : role == 'staff' ? 1
           : 0;
    }
    // Effective rank of the caller; -1 when no profile or disabled.
    function callerRank() {
      return hasProfile() && profile().get('disabled', false) != true
        ? roleRank(profile().get('role', 'user'))
        : -1;
    }
    // Anonymous storefront checkout: a NEW web order (status yangi / no channel).
    function isValidWebOrder() {
      let d = request.resource.data;
      return d.clientPhone is string
        && d.basketItems is list
        && d.totalPrice is number
        && (!('status' in d) || d.status == 'yangi')
        && (!('channel' in d) || d.channel == 'web');
    }
    // In-store POS sale: created by staff+, already completed (sotildi).
    function isValidStoreSale() {
      let d = request.resource.data;
      return callerRank() >= 1
        && d.channel == 'store'
        && d.basketItems is list
        && d.totalPrice is number
        && d.status == 'sotildi';
    }

    // Products — public storefront read; manager+ creates/edits/deletes.
    // A POS cashier (staff+, rank 1) may update ONLY the quantity field, and
    // only downward — so a sale can decrement stock without letting a cashier
    // edit prices/details or inflate stock.
    match /products/{id} {
      allow read: if true;
      allow create, delete: if callerRank() >= 2;
      allow update: if callerRank() >= 2
        || (callerRank() >= 1
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity'])
            && request.resource.data.quantity is number
            && request.resource.data.quantity <= resource.data.get('quantity', 0));
    }
    // Categories — public read; manager+ writes.
    match /categories/{id} {
      allow read: if true;
      allow write: if callerRank() >= 2;
    }

    // Orders — anyone places an order; any active staff reads + updates status;
    // only admin+ deletes.
    match /orders/{id} {
      allow read: if callerRank() >= 1;
      allow create: if isValidWebOrder() || isValidStoreSale();
      allow update: if callerRank() >= 1;
      allow delete: if callerRank() >= 3;
    }

    // Customers CRM (PII) — manager+.
    match /customers/{phone} {
      allow read, write: if callerRank() >= 2;
    }

    // Inventory movement ledger (kirim/chiqim/tuzatish) — manager+ records and
    // reads; immutable once written (no client update/delete) so the audit trail
    // can't be quietly rewritten. The matching products.quantity write in the
    // same batch is already covered by the products rule (manager+).
    match /stockMovements/{id} {
      allow read: if callerRank() >= 2;
      allow create: if callerRank() >= 2
        && request.resource.data.delta is number
        && request.resource.data.productId is string;
      allow update, delete: if false;
    }

    // Staff accounts. Self-signup may create ONLY a non-privileged 'user'.
    // admin+ manages others — never themselves, never at/above their own rank.
    match /user/{uid} {
      allow read: if request.auth.uid == uid || callerRank() >= 3;
      allow create: if (request.auth != null
                        && request.auth.uid == uid
                        && request.resource.data.get('role', 'user') == 'user')
                     || (callerRank() >= 3
                        && roleRank(request.resource.data.get('role', 'user')) <= callerRank());
      allow update: if callerRank() >= 3
                     && request.auth.uid != uid
                     && roleRank(resource.data.get('role', 'user')) <= callerRank()
                     && roleRank(request.resource.data.get('role', 'user')) <= callerRank();
      allow delete: if callerRank() >= 3
                     && request.auth.uid != uid
                     && roleRank(resource.data.get('role', 'user')) <= callerRank();
    }
  }
}
