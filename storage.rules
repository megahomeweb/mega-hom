rules_version = '2';

// megahome.uz Cloud Storage rules.
// Product images are shown on the public storefront (public read) but may only
// be uploaded/changed/deleted by a CATALOG MANAGER — owner / admin / manager,
// i.e. the SAME manager+ boundary firestore.rules uses for product writes
// (callerRank() >= 2). Role is read from the UID-keyed user doc (user/<uid>);
// a disabled account is rejected.
//
// IMPORTANT: the previous rule required role == 'admin' EXACTLY. That silently
// rejected an `owner` (a HIGHER role, but a different string) and every
// `manager` with storage/unauthorized — so for those accounts the image upload
// just hung on the spinner and the product could never be saved. Matching the
// Firestore manager+ boundary fixes that.
// Everything outside products/ is denied by default.

service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/user/$(request.auth.uid)).data.get('disabled', false) != true
        && firestore.get(/databases/(default)/documents/user/$(request.auth.uid)).data.get('role', 'user') in ['owner', 'admin', 'manager'];
    }
  }
}
