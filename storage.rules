rules_version = '2';

// megahome.uz Cloud Storage rules.
//
// Product images: public read (shown on the storefront); any SIGNED-IN user may
// upload/replace/delete an image file (limited to images, <20MB).
//
// WHY NOT gate by the manager+ role here? Reading the caller's role lives in
// Firestore (user/<uid>), and calling firestore.get() FROM Storage rules is a
// "cross-service" call. This project is not configured for cross-service rules,
// so every such call fails with:
//   "our rules make use of cross-service database calls, but your project is not
//    configured to execute those calls"
// → the rule errors out and EVERY upload is denied (that was the real cause of
// the "Rasmni yuklab boʼlmadi" upload failures). Gating on request.auth removes
// that dependency so uploads work reliably with no extra project configuration.
//
// This does NOT weaken the catalog boundary: to make an image appear on the
// store you must also write a product DOCUMENT, and firestore.rules already
// restricts product writes to manager+ (rank >= 2) — an intra-Firestore call
// that always works. The worst an authenticated non-manager could do is upload
// an orphan file no product references. Size + content-type caps limit abuse.
//
// Everything outside products/ is denied by default.

service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
